model Booking {
  id   String @id @default(cuid())
  code String @unique

  courts Court[] @relation("BookingCourts")

  fullName      String
  contactNumber String?
  emailAddress  String?
  startTime     DateTime
  endTime       DateTime

  status String @default("pending") // pending, confirmed, cancelled, reserved

  totalPrice         Float?
  proofOfPaymentLink String
  notes              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([startTime, endTime])
}