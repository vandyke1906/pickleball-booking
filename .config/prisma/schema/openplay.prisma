model OpenPlay {
  id String @id @default(cuid())

  startedAt                           DateTime?
  isCompleted                         Boolean        @default(false)
  startTime                           DateTime
  endTime                             DateTime
  transitionMinutes                   Int            @default(60)
  preparationSeconds                  Int            @default(20)
  announcementMinutesBeforeTransition Int            @default(5)
  status                              OpenPlayStatus @default(pending)

  queues  LineupQueue[]
  players OpenPlayPlayer[] @relation("OpenPlayPlayers")
  courts  Court[]
  groups  OpenPlayGroup[]

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  registrationCodes RegistrationCode[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startTime, endTime])
  @@index([startTime, status])
  @@index([organizationId, status])
}
model RegistrationCode {
  id          String   @id @default(cuid())
  code        String   
  openPlayId  String
  openPlay    OpenPlay @relation(fields: [openPlayId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@unique([openPlayId, code])
}

model OpenPlayGroup {
  id String @id @default(cuid())

  openPlayId String
  openPlay   OpenPlay @relation(fields: [openPlayId], references: [id], onDelete: Cascade)

  skills PlayerSkill[]
  status QueueStatus   @default(waiting)

  queues LineupQueue[] @relation("LineupQueues")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([openPlayId])
	@@map("OpenPlayCourt")
}

model OpenPlayPlayer {
  id         String   @id @default(cuid())
  openPlayId String
  openPlay   OpenPlay @relation("OpenPlayPlayers", fields: [openPlayId], references: [id], onDelete: Cascade)

  code          String
  playerName    String
  skill         PlayerSkill   @default(beginner)
  contactNumber String?
  emailAddress  String?
  registeredAt  DateTime      @default(now())
  lineupQueues  LineupQueue[]

  totalPlayTime Int       @default(180) // in minutes default 30 minutes
  startAt       DateTime?
  endAt         DateTime?
  order         Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([openPlayId, code])
  @@unique([openPlayId, playerName])
  @@index([skill])
  @@index([openPlayId])
}

model LineupQueue {
  id String @id @default(cuid())

  openPlayId String
  openPlay   OpenPlay @relation(fields: [openPlayId], references: [id], onDelete: Cascade)

  playerId String
  player   OpenPlayPlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)

  status QueueStatus @default(waiting)

  openPlayGroupId String
  openPlayGroup   OpenPlayGroup @relation("LineupQueues", fields: [openPlayGroupId], references: [id], onDelete: Cascade)

  scheduledAt     DateTime?
  endedAt         DateTime?
  assignedCourtId String?
  assignedCourt   Court?    @relation(fields: [assignedCourtId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([playerId, openPlayId, openPlayGroupId])
  @@index([status])
  @@index([playerId])
}

enum QueueStatus {
  waiting
  queued
  scheduled
  playing
  finished
}

enum OpenPlayStatus {
  active
  pending
  completed
  cancelled
}

enum PlayerSkill {
  beginner
  novice_low
  novice_high
  intermediate
  advanced
}
