model OpenPlay {
  id String @id @default(cuid())

  isActive                            Boolean        @default(false)
  startedAt                           DateTime?
  isCompleted                         Boolean        @default(false)
  startTime                           DateTime
  endTime                             DateTime
  transitionMinutes                   Int            @default(60)
  preparationSeconds                  Int            @default(20)
  announcementMinutesBeforeTransition Int            @default(5)
  status                              OpenPlayStatus @default(pending)
  
  queues  LineupQueue[]
  players OpenPlayPlayer[] @relation("OpenPlayPlayers")
  courts OpenPlayCourt[]

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([startTime, endTime])
  @@index([startTime, status])
  @@index([organizationId, status])
}

model OpenPlayCourt {
  id String @id @default(cuid())

  openPlayId String
  openPlay   OpenPlay @relation(fields: [openPlayId], references: [id], onDelete: Cascade)
  
  courts         Court[]
  skills         PlayerSkill[]
  status QueueStatus @default(waiting)

  scheduledAt DateTime?
  endedAt     DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([openPlayId])
}


model OpenPlayPlayer {
  id         String   @id @default(cuid())
  openPlayId String
  openPlay   OpenPlay @relation("OpenPlayPlayers", fields: [openPlayId], references: [id], onDelete: Cascade)

  code          String
  playerName    String
  skill         PlayerSkill @default(beginner)
  contactNumber String?
  emailAddress  String?
  registeredAt  DateTime      @default(now())
  lineupQueues  LineupQueue[]

  totalPlayTime Int       @default(180) // in minutes default 30 minutes
  startAt       DateTime?
  endAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([openPlayId, skill, code])
  @@index([skill])
}

model LineupQueue {
  id String @id @default(cuid())

  openPlayId String
  openPlay   OpenPlay @relation(fields: [openPlayId], references: [id], onDelete: Cascade)

  playerId String
  player   OpenPlayPlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)

  status QueueStatus @default(waiting)

  scheduledAt DateTime?
  endedAt     DateTime?
  courtId     String?
  court       Court?    @relation("LineupQueues", fields: [courtId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([playerId, openPlayId])
  @@index([status])
  @@index([playerId])
}

enum QueueStatus {
  waiting
  queued
  playing
  finished
}

enum OpenPlayStatus {
  active
  pending
  completed
  cancelled
}

enum PlayerSkill {
  beginner
  novice_low
  novice_high
  intermediate
  advanced
}