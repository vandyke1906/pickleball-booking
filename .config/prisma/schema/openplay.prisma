model OpenPlay {
  id   String @id @default(cuid())

  courts Court[] @relation("OpenPlayCourts")

  startTime DateTime
  endTime   DateTime
  transitionMinutes Int @default(60)
  status OpenPlayStatus @default(pending)

  queues LineupQueue[]
  players OpenPlayPlayer[] @relation("OpenPlayPlayers")

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startTime, endTime])
  @@index([startTime, status])
  @@index([organizationId, status])
}

model OpenPlayPlayer {
  id        String   @id @default(cuid())
  openPlay  OpenPlay @relation("OpenPlayPlayers", fields: [openPlayId], references: [id], onDelete: Cascade)
  openPlayId String

  code String
  playerName      String
  contactNumber   String?
  emailAddress    String?
  registeredAt    DateTime @default(now())
  lineupQueues    LineupQueue[]

  totalPlayTime Int @default(180) // in minutes default 30 minutes
  startAt   DateTime?
  endAt     DateTime? 

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([openPlayId, code])
}

model LineupQueue {
  id          String        @id @default(cuid())
  
  openPlayId    String
  openPlay      OpenPlay @relation(fields: [openPlayId], references: [id], onDelete: Cascade)

  playerId    String
  player      OpenPlayPlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)
 
  status      QueueStatus @default(waiting)
  scheduledAt DateTime?     

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([playerId])
}

enum QueueStatus {
  waiting
  playing
  finished
}
enum OpenPlayStatus {
  active
  pending 
  completed
  cancelled
}